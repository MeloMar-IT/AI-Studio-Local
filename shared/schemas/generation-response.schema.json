{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generation Response",
  "description": "The immediate response from the worker when a generation job is created",
  "type": "object",
  "properties": {
    "job_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string"
    },
    "message": {
      "type": "string"
    }
  },
  "required": ["job_id", "status"]
}
