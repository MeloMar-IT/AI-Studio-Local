{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generation Request",
  "description": "A request sent to the worker to start a generation job",
  "type": "object",
  "properties": {
    "project_id": { "type": "string" },
    "scene_id": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["text-to-video", "image-to-video", "audio-to-video", "retake"]
    },
    "model_id": { "type": "string" },
    "prompt": { "type": "string" },
    "negative_prompt": { "type": "string" },
    "seed": { "type": "integer" },
    "duration_seconds": { "type": "number" },
    "aspect_ratio": { "type": "string" },
    "resolution": {
      "type": "object",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      }
    },
    "steps": { "type": "integer" },
    "guidance": { "type": "number" },
    "input_image_path": { "type": "string" },
    "input_audio_path": { "type": "string" },
    "input_video_path": { "type": "string" },
    "retake_start_seconds": { "type": "number" },
    "retake_end_seconds": { "type": "number" },
    "output_directory": { "type": "string" }
  },
  "required": ["project_id", "scene_id", "mode", "model_id", "prompt", "output_directory"]
}
