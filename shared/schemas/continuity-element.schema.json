{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Continuity Element",
  "description": "A reusable creative element",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string",
      "enum": [
        "character",
        "location",
        "style",
        "camera",
        "audio",
        "brand",
        "prompt_block",
        "lora",
        "export_template"
      ]
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "prompt_block": {
      "type": "string"
    },
    "negative_prompt": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "modified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "type", "name", "prompt_block", "created_at", "modified_at"]
}
